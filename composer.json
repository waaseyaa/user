{
    "name": "waaseyaa/user",
    "description": "User entity, authentication, and session management for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {
            "type": "path",
            "url": "../entity"
        },
        {
            "type": "path",
            "url": "../plugin"
        },
        {
            "type": "path",
            "url": "../cache"
        },
        {
            "type": "path",
            "url": "../typed-data"
        },
        {
            "type": "path",
            "url": "../field"
        },
        {
            "type": "path",
            "url": "../access"
        },
        {
            "type": "path",
            "url": "../config"
        },
        {
            "type": "path",
            "url": "../foundation"
        },
        {
            "type": "path",
            "url": "../queue"
        },
        {
            "type": "path",
            "url": "../mail"
        },
        {
            "type": "path",
            "url": "../ssr"
        }
    ],
    "require": {
        "php": ">=8.4",
        "waaseyaa/entity": "^0.1.0-alpha.150",
        "waaseyaa/access": "^0.1.0-alpha.150",
        "waaseyaa/foundation": "^0.1.0-alpha.150",
        "waaseyaa/mail": "^0.1.0-alpha.150",
        "symfony/http-foundation": "^7.0",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\User\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\User\\Tests\\": "tests/"
        }
    },
    "extra": {
        "waaseyaa": {
            "providers": [
                "Waaseyaa\\User\\UserServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.1.x-dev",
            "dev-develop/v1.1": "0.1.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
