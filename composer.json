{
    "name": "waaseyaa/user",
    "description": "User entity, authentication, and session management for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {"type": "path", "url": "../entity"},
        {"type": "path", "url": "../plugin"},
        {"type": "path", "url": "../cache"},
        {"type": "path", "url": "../typed-data"},
        {"type": "path", "url": "../field"},
        {"type": "path", "url": "../access"},
        {"type": "path", "url": "../config"},
        {"type": "path", "url": "../foundation"},
        {"type": "path", "url": "../queue"}
    ],
    "require": {
        "php": ">=8.3",
        "waaseyaa/entity": "^0.1",
        "waaseyaa/access": "^0.1",
        "waaseyaa/foundation": "^0.1",
        "symfony/http-foundation": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\User\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\User\\Tests\\": "tests/"
        }
    },
    "extra": {
        "waaseyaa": {
            "providers": ["Waaseyaa\\User\\UserServiceProvider"]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
